# Build output — we build inside Docker, don't need local target/
target/

# Git history — not needed in the image
.git/
.gitignore

# IDE files
.idea/
*.iml
.vscode/

# Local secrets — NEVER let these into an image
.env
.env.*

# Tests — not needed in prod image
src/test/

# CI config — not needed in image
.github/

# Logs
*.log
logs/

# Docker files themselves
Dockerfile*
docker-compose*
.dockerignore

# Docs
README*
*.md